{
  "schemaVersion": "1.0",
  "documents": {
    "perSkill": {
      "pathPattern": "functions/index/v1/<skillId>.json",
      "required": [
        "schemaVersion",
        "id",
        "displayName",
        "description",
        "source",
        "runtime",
        "io",
        "quality"
      ],
      "fields": {
        "schemaVersion": { "type": "string", "const": "1.0" },
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string", "maxLength": 240 },
        "source": {
          "type": "object",
          "required": ["files", "contentHash"],
          "fields": {
            "contentPrefix": { "type": "string", "default": "functions/" },
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "kind"],
                "fields": {
                  "key": { "type": "string" },
                  "kind": { "type": "string", "enum": ["instructions", "rules", "prompt", "other"] }
                }
              }
            },
            "contentHash": { "type": "string", "pattern": "^sha256:" }
          }
        },
        "runtime": {
          "type": "object",
          "required": ["callName"],
          "fields": {
            "callName": { "type": "string" },
            "modes": { "type": "array", "items": { "type": "string", "enum": ["weak", "normal", "strong"] }, "default": ["normal"] },
            "defaults": { "type": "object" }
          }
        },
        "io": {
          "type": "object",
          "required": ["input", "output"],
          "fields": {
            "input": { "type": "object", "required": ["type", "properties"], "restrictedJsonSchemaV1": true },
            "output": { "type": "object", "required": ["type", "properties"], "restrictedJsonSchemaV1": true }
          }
        },
        "examples": { "type": "array", "default": [] },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "quality": {
          "type": "object",
          "required": ["confidence"],
          "fields": {
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "notes": { "type": "array", "items": { "type": "string" }, "default": [] }
          }
        }
      }
    },
    "aggregate": {
      "path": "functions/index.v1.json",
      "required": ["schemaVersion", "generatedAt", "skills"],
      "fields": {
        "schemaVersion": { "type": "string", "const": "1.0" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "generator": { "type": "object" },
        "skills": {
          "type": "array",
          "items": { "type": "object", "required": ["$refKey"], "fields": { "$refKey": { "type": "string" } } }
        }
      }
    },
    "meta": {
      "path": "functions/index/v1/_meta.json",
      "required": ["schemaVersion", "generatedAt", "stats"],
      "fields": {
        "schemaVersion": { "type": "string", "const": "1.0" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "stats": { "type": "object" },
        "errors": { "type": "array", "default": [] }
      }
    }
  }
}
