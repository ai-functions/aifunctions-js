# OpenRouter (required for backend: "openrouter")
OPENROUTER_API_KEY=sk-or-...

# Optional attribution (HTTP-Referer and X-OpenRouter-Title)
OPENROUTER_APP_URL=https://yourapp.example
OPENROUTER_APP_NAME=My App

# local llama.cpp
LLAMA_CPP_MODEL_PATH=./models/tinyllama.gguf
LLAMA_CPP_THREADS=4
LLAMA_CPP_CONTEXT_SIZE=4096

# local Transformers.js
TRANSFORMERS_JS_MODEL_ID=Xenova/tiny-random-Gpt2
TRANSFORMERS_JS_CACHE_DIR=./.cache/transformers
